---
import { getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import LinkButton from "@components/LinkButton.astro";
import Hr from "@components/Hr.astro";
import Card from "@components/Card";
import Socials from "@components/Socials.astro";
import getSortedPosts from "@utils/getSortedPosts";
import { SOCIALS } from "@config";

const posts = await getCollection("blog");
const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
const socialCount = SOCIALS.filter(social => social.active).length;
---

<Layout>
  <Header />
  <main id="main-content">
    <section id="hero">
      <h1 class="hero-name">Timothy Kyalo 👋</h1>
      <div class="hero-grid">
        <div class="bio-text">
          <p>
            I am a <strong>Construction Project Manager</strong> specializing in <strong>Interior Fit-Outs</strong> and <strong>Virtual Project Controls</strong>. I bridge the gap between physical site execution in Nairobi and high-precision digital scheduling for global developers.
          </p>
          <p>
            Managing infrastructure valued above <strong>KES 20M</strong>, I leverage <strong>MS Project</strong> and <strong>ArchiCAD</strong> to maintain budget variances under 5% and reduce material wastage by 20%.
          </p>
        </div>
        <img 
          src="/images/CPM%20TIMO.jpg" 
          alt="Timothy Kyalo" 
          class="hero-img-technical"
        />
      </div>

      {socialCount > 0 && (
        <div class="social-wrapper">
          <div class="social-links">System Inquiry: </div>
          <Socials />
        </div>
      )}
    </section>

    <Hr />

    <section id="projects" class="mt-10">
      <h2 class="section-title-eng">Major Projects & Case Studies</h2>
      <div class="dossier-grid">
        
        <div class="dossier-card card-library">
          <div class="dossier-overlay">
            <h3 class="dossier-h3">Aga Khan High Library Fit-Out</h3>
            <span class="dossier-status">Status: 97% Completion Reached March 2026</span>
            <p class="dossier-p">
              Rescued project from 50% stagnation. Orchestrated MEP, HVAC, and joinery convergence to deliver a high-spec academic environment under rigid timelines.
            </p>
          </div>
        </div>

        <div class="dossier-card card-tatu">
          <div class="dossier-overlay">
            <h3 class="dossier-h3">NCBA Tatu City Office</h3>
            <p class="dossier-p">
              Full interior fit-out in &lt;90 days. Managed the "System of Site"—coordinating precision labor output and high-spec material procurement in the Westlands/Tatu corridor.
            </p>
          </div>
        </div>

        <div class="dossier-card card-virtual">
          <div class="dossier-overlay">
            <h3 class="dossier-h3">Virtual Project Controls</h3>
            <span class="dossier-status-alt">Remote / Global Services</span>
            <p class="dossier-p">
              Providing remote scheduling, cost valuation, and ArchiCAD shop drawings for US-based and local developers using a 100% digital "Cloud Construction" workflow.
            </p>
          </div>
        </div>

        <div class="dossier-card card-ict">
          <div class="dossier-overlay">
            <h3 class="dossier-h3">Ministry of ICT Fit-Out</h3>
            <p class="dossier-p">
              Delivered executive offices for PS & CS. 6-week turnaround requiring
